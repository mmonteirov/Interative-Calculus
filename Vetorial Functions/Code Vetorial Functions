<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explorador de Funções Vetoriais</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/10.0.0/math.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            color: #334155;
        }
        #visualizador-3d {
            width: 100%;
            height: 550px;
            background-color: #ffffff;
            border-radius: 1rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
            position: relative;
            overflow: hidden;
        }
        .campo-input {
            transition: all 0.2s ease;
        }
        .campo-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }
    </style>
</head>
<body class="p-4 md:p-8 flex flex-col lg:flex-row gap-8">

    <div class="w-full lg:w-1/3 space-y-6 bg-white p-8 rounded-2xl shadow-xl border border-slate-100">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 mb-2">Função Vetorial</h1>
            <p class="text-slate-500 text-sm">Defina as equações paramétricas em função de <code class="bg-slate-100 px-1 rounded">t</code>.</p>
        </div>

        <div class="space-y-4">
            <div class="grid grid-cols-1 gap-4">
                <div>
                    <label class="text-xs font-semibold uppercase tracking-wider text-slate-400">Componente X(t)</label>
                    <input id="input-x" type="text" value="3*cos(t)" class="campo-input w-full mt-1 p-3 border border-slate-200 rounded-xl outline-none">
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase tracking-wider text-slate-400">Componente Y(t)</label>
                    <input id="input-y" type="text" value="3*sin(t)" class="campo-input w-full mt-1 p-3 border border-slate-200 rounded-xl outline-none">
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase tracking-wider text-slate-400">Componente Z(t)</label>
                    <input id="input-z" type="text" value="0.5*t" class="campo-input w-full mt-1 p-3 border border-slate-200 rounded-xl outline-none">
                </div>
            </div>

            <div class="flex gap-4">
                <div class="flex-1">
                    <label class="text-xs font-semibold uppercase tracking-wider text-slate-400">Início (t)</label>
                    <input id="t-inicial" type="number" value="0" class="campo-input w-full mt-1 p-3 border border-slate-200 rounded-xl outline-none">
                </div>
                <div class="flex-1">
                    <label class="text-xs font-semibold uppercase tracking-wider text-slate-400">Fim (t)</label>
                    <input id="t-final" type="number" value="12" class="campo-input w-full mt-1 p-3 border border-slate-200 rounded-xl outline-none">
                </div>
            </div>

            <div class="pt-4 space-y-3">
                <button id="btn-atualizar" class="w-full py-4 bg-indigo-600 text-white font-semibold rounded-xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 active:scale-[0.98] transition-all">
                    Visualizar Trajetória
                </button>
                <button id="btn-vetores" class="w-full py-4 bg-slate-800 text-white font-semibold rounded-xl shadow-lg shadow-slate-200 hover:bg-slate-900 active:scale-[0.98] transition-all">
                    Analisar Velocidade e Aceleração
                </button>
            </div>
        </div>

        <div id="status-erro" class="text-sm text-red-500 bg-red-50 p-3 rounded-lg hidden"></div>
        
        <div id="painel-dados" class="bg-slate-50 p-5 rounded-2xl border border-slate-100 hidden">
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-3">Dados Cinemáticos</h3>
            <div id="conteudo-dados" class="text-sm text-slate-600 space-y-4"></div>
        </div>
    </div>

    <div id="visualizador-3d" class="flex-1"></div>

    <script>
        window.onload = function() {
            let cena, camera, renderizador, controles;
            let objetoCurva = null;
            let setaVelocidade = null;
            let setaAceleracao = null;
            
            const areaVisual = document.getElementById('visualizador-3d');
            const feedbackErro = document.getElementById('status-erro');
            const painelDados = document.getElementById('painel-dados');
            const textoDados = document.getElementById('conteudo-dados');

            function prepararAmbiente() {
                cena = new THREE.Scene();
                cena.background = new THREE.Color(0xffffff);

                camera = new THREE.PerspectiveCamera(50, areaVisual.clientWidth / areaVisual.clientHeight, 0.1, 1000);
                camera.position.set(15, 15, 15);

                renderizador = new THREE.WebGLRenderer({ antialias: true });
                renderizador.setSize(areaVisual.clientWidth, areaVisual.clientHeight);
                renderizador.setPixelRatio(window.devicePixelRatio);
                areaVisual.appendChild(renderizador.domElement);

                controles = new THREE.OrbitControls(camera, renderizador.domElement);
                controles.enableDamping = true;

                const grade = new THREE.GridHelper(20, 20, 0xe2e8f0, 0xf1f5f9);
                cena.add(grade);

                const eixos = new THREE.AxesHelper(10);
                cena.add(eixos);

                const luzAmbiente = new THREE.AmbientLight(0xffffff, 0.7);
                cena.add(luzAmbiente);

                const luzPonto = new THREE.PointLight(0xffffff, 0.5);
                luzPonto.position.set(10, 20, 10);
                cena.add(luzPonto);

                window.addEventListener('resize', () => {
                    camera.aspect = areaVisual.clientWidth / areaVisual.clientHeight;
                    camera.updateProjectionMatrix();
                    renderizador.setSize(areaVisual.clientWidth, areaVisual.clientHeight);
                });

                executarCiclo();
            }

            function executarCiclo() {
                requestAnimationFrame(executarCiclo);
                controles.update();
                renderizador.render(cena, camera);
            }

            function processarExpressao(texto) {
                try {
                    const formula = math.parse(texto);
                    return (tempo) => formula.evaluate({ t: tempo });
                } catch (erro) {
                    exibirErro(`Erro na fórmula: ${erro.message}`);
                    return null;
                }
            }

            function exibirErro(msg) {
                feedbackErro.textContent = msg;
                feedbackErro.classList.remove('hidden');
                setTimeout(() => feedbackErro.classList.add('hidden'), 5000);
            }

            function limparElementosFisicos() {
                if (setaVelocidade) cena.remove(setaVelocidade);
                if (setaAceleracao) cena.remove(setaAceleracao);
                setaVelocidade = null;
                setaAceleracao = null;
                painelDados.classList.add('hidden');
            }

            function gerarCurva() {
                if (objetoCurva) cena.remove(objetoCurva);
                limparElementosFisicos();

                const expX = document.getElementById('input-x').value;
                const expY = document.getElementById('input-y').value;
                const expZ = document.getElementById('input-z').value;
                const t0 = parseFloat(document.getElementById('t-inicial').value);
                const t1 = parseFloat(document.getElementById('t-final').value);

                const fx = processarExpressao(expX);
                const fy = processarExpressao(expY);
                const fz = processarExpressao(expZ);

                if (!fx || !fy || !fz) return;

                const pontosValidos = [];
                const resolucao = 500;
                const incremento = (t1 - t0) / resolucao;

                for (let i = 0; i <= resolucao; i++) {
                    const t = t0 + i * incremento;
                    pontosValidos.push(new THREE.Vector3(fx(t), fz(t), -fy(t)));
                }

                const geometria = new THREE.BufferGeometry().setFromPoints(pontosValidos);
                const material = new THREE.LineBasicMaterial({ color: 0x6366f1, linewidth: 2 });
                objetoCurva = new THREE.Line(geometria, material);
                cena.add(objetoCurva);
            }

            function analisarMovimento() {
                limparElementosFisicos();

                const expX = document.getElementById('input-x').value;
                const expY = document.getElementById('input-y').value;
                const expZ = document.getElementById('input-z').value;
                const tFinal = parseFloat(document.getElementById('t-final').value);

                try {
                    const dx = math.derivative(expX, 't');
                    const dy = math.derivative(expY, 't');
                    const dz = math.derivative(expZ, 't');

                    const d2x = math.derivative(dx, 't');
                    const d2y = math.derivative(dy, 't');
                    const d2z = math.derivative(dz, 't');

                    const momento = { t: tFinal };

                    const pos = {
                        x: math.evaluate(expX, momento),
                        y: math.evaluate(expY, momento),
                        z: math.evaluate(expZ, momento)
                    };

                    const vel = {
                        x: dx.evaluate(momento),
                        y: dy.evaluate(momento),
                        z: dz.evaluate(momento)
                    };

                    const ace = {
                        x: d2x.evaluate(momento),
                        y: d2y.evaluate(momento),
                        z: d2z.evaluate(momento)
                    };

                    const pontoOrigem = new THREE.Vector3(pos.x, pos.z, -pos.y);
                    const direcaoVel = new THREE.Vector3(vel.x, vel.z, -vel.y);
                    const direcaoAce = new THREE.Vector3(ace.x, ace.z, -ace.y);

                    setaVelocidade = new THREE.ArrowHelper(direcaoVel.clone().normalize(), pontoOrigem, direcaoVel.length() || 0.1, 0x10b981, 0.5, 0.2);
                    setaAceleracao = new THREE.ArrowHelper(direcaoAce.clone().normalize(), pontoOrigem, direcaoAce.length() || 0.1, 0xef4444, 0.5, 0.2);

                    cena.add(setaVelocidade);
                    cena.add(setaAceleracao);

                    painelDados.classList.remove('hidden');
                    textoDados.innerHTML = `
                        <div>
                            <p class="text-indigo-600 font-semibold">Posição r(t)</p>
                            <p class="font-mono text-xs">(${pos.x.toFixed(2)}, ${pos.y.toFixed(2)}, ${pos.z.toFixed(2)})</p>
                        </div>
                        <div>
                            <p class="text-emerald-600 font-semibold">Velocidade v(t)</p>
                            <p class="font-mono text-xs">(${vel.x.toFixed(2)}, ${vel.y.toFixed(2)}, ${vel.z.toFixed(2)})</p>
                        </div>
                        <div>
                            <p class="text-red-500 font-semibold">Aceleração a(t)</p>
                            <p class="font-mono text-xs">(${ace.x.toFixed(2)}, ${ace.y.toFixed(2)}, ${ace.z.toFixed(2)})</p>
                        </div>
                    `;

                } catch (e) {
                    exibirErro("Cálculo impossível para estas funções.");
                }
            }

            document.getElementById('btn-atualizar').onclick = gerarCurva;
            document.getElementById('btn-vetores').onclick = analisarMovimento;

            prepararAmbiente();
            gerarCurva();
        };
    </script>
</body>
</html>
